{
  "bitcoin_rpc": {
    "url": "http://fractald:10332",
    "user": "REPLACE_RPC_USER",
    "password": "REPLACE_RPC_PASSWORD",
    "network": "mainnet"
  },
  "signing": {
    "private_key_wif": "REPLACE_PRIVATE_KEY_WIF",
    "change_address": "REPLACE_CHANGE_ADDRESS",
    "initial_utxos": [
      {
        "txid": "REPLACE_UTXO_TXID",
        "vout": 0,
        "amount_sat": 100000,
        "address": "REPLACE_UTXO_ADDRESS",
        "script_pub_key": "REPLACE_UTXO_SCRIPT_PUB_KEY",
        "address_type": "p2wpkh"
      }
    ]
  },
  "state_api": {
    "base_url": "http://fractal-indexer:8000",
    "timeout": 5000000000,
    "auth": "",
    "provider": "query-fip101"
  },
  "fee_api": {
    "base_url": "https://mempool.fractalbitcoin.io",
    "timeout": 5000000000,
    "strategy": "halfhour",
    "min_fee_rate_sat_vb": 1,
    "max_fee_rate_sat_vb": 0,
    "fixed_fee_rate_sat_vb": 0
  },
  "register": {
    "index_ratio_bp": 100,
    "reward_addr_type": "p2wpkh",
    "reward_addr": "REPLACE_REWARD_ADDRESS",
    "name": "REPLACE_INDEXER_NAME",
    "indexer_id": "REPLACE_EXISTING_INDEXER_ID_OR_EMPTY"
  },
  "scan": {
    "start_height": REPLACE_START_HEIGHT,
    "poll_interval": 30000000000,
    "target_block_version": 539361536,
    "required_confirmations": 1,
    "max_reorg_depth": 100
  },
  "tx": {
    "send_change_min_value": 546
  },
  "database": {
    "sqlite_path": "/app/data/publisher.db"
  },
  "runtime": {
    "mode": "default" OR "unisat_open_api",
    "unisat_open_api_url": "https://open-api.unisat.io",
    "unisat_open_api_key": "REQUIRED_WHEN_MODE_IS_UNISAT_OPEN_API_OR_LOCAL_UTXO_OPEN_API_REFILL_IS_TRUE",
    "local_utxo_open_api_refill": false,
    "dry_run": false,
    "disable_broadcast": false,
    "health_addr": ":8080"
  }
}

